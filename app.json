{
  "expo": {
    "name": "colorohm",
    "slug": "colorohm",
    "version": "1.2.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0E11"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0E0E11",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "me.rsmk.colorohm"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "scheme": "colorohm",
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ab4eae6e-e5be-40a4-8831-c47f375bc2a6"
      }
    },
    "owner": "rsmk27s-organization"
  }
}
